rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function jobAssignedTo(jobId) {
      return firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.assignedTo;
    }

    match /jobs/{jobId}/{fileName} {
      allow read: if isSignedIn() && (isAdmin() || jobAssignedTo(jobId) == request.auth.uid);

      allow write: if isSignedIn() &&
        (isAdmin() || jobAssignedTo(jobId) == request.auth.uid) &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');

      allow delete: if isSignedIn() && (isAdmin() || jobAssignedTo(jobId) == request.auth.uid);
    }
  }
}
